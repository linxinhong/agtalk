{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/.schemas/config.schema.json",
  "productName": "agtalk",
  "version": "0.1.0",
  "identifier": "com.agtalk.app",
  "build": {
    "frontendDist": "/Users/linxinhong/projects/agtalk-office/dist",
    "devUrl": "http://localhost:1421",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "agtalk",
        "width": 900,
        "height": 650,
        "minWidth": 560,
        "minHeight": 400,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
